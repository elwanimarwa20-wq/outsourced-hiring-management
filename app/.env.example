# Copy to .env and fill in. Never commit .env.

# --- Database ---
# Migration-owner connection (used by `prisma migrate`)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/osf_hiring?schema=public"
# Restricted runtime role so Row-Level Security applies (see migration)
RUNTIME_DATABASE_URL="postgresql://app_runtime:CHANGE_ME@localhost:5432/osf_hiring?schema=public"

# --- Auth.js ---
AUTH_SECRET="generate-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- SSO: OIDC / OAuth 2.0 (Azure AD, Okta, UAE PASS) ---
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""

# --- SSO: SAML 2.0 ---
SAML_IDP_ENTRY_POINT=""
SAML_IDP_ISSUER=""
SAML_IDP_CERT=""
SAML_SP_ENTITY_ID="urn:osf-hiring:sp"
SAML_SP_CALLBACK_URL="http://localhost:3000/api/auth/saml/acs"

# --- Dev-only credentials login (MUST be unset/false in production) ---
ENABLE_DEV_LOGIN="true"

# --- Uploads (prototype: local disk; production: object storage) ---
# UPLOAD_DIR="/var/lib/osf-hiring/uploads"
